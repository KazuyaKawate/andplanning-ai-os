# ============================================================
# AI OS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Database ──────────────────────────────────────────────
# SQLite (default, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./data/aios.db

# PostgreSQL (production recommended)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aios

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Backend Auth ─────────────────────────────────────────
# Legacy simple bearer token (optional, deprecated — use JWT_SECRET_KEY instead)
API_SECRET_KEY=

# JWT secret for user authentication — CHANGE THIS in production!
# Generate a secure value: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-please-use-long-random-string

# ── AI Provider API Keys ─────────────────────────────────
# These are fallback keys used if the DB settings row has empty keys.
# Recommended: configure keys via the Settings page in the UI instead.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# AI Studio で発行される現行の Auth キー (AQ.Ab... 形式)。旧 AIza... 形式も可。
GOOGLE_API_KEY=AQ.Ab...
