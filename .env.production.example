# ─────────────────────────────────────────────────────────────────────────────
# AIOS Production Environment Variables Configuration Template
# Place a completed copy of this file at: backend/.env on your server.
# Do NOT commit your actual .env file to public repositories!
# ─────────────────────────────────────────────────────────────────────────────

# --- DATABASE persistence ---
DATABASE_URL=sqlite+aiosqlite:////app/data/aios.db

# --- CORS ORIGIN RESTRICTION ---
# Restrict to your exact production domain to block unauthorized cross-origin requests.
ALLOWED_ORIGINS=https://ap-aios.com,https://www.ap-aios.com

# --- JWT SECURITY ---
# MUST generate a cryptographically secure 64-character hex key for signing sessions.
# Generate command: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=ReplaceWithSecureHexKeyGeneratedOnTheServer

# --- BACKEND ACCESS CONTROL ---
# Custom bearer token for protecting deep API nodes and micro-services.
API_SECRET_KEY=ReplaceWithAnotherSecureHexKeyGeneratedOnTheServer

# --- AI API PROVIDERS (Fill in your active keys) ---
OPENAI_API_KEY=sk-proj-YourProductionOpenAiKeyHere
ANTHROPIC_API_KEY=sk-ant-YourProductionAnthropicKeyHere
GOOGLE_API_KEY=YourProductionGoogleGeminiKeyHere
OLLAMA_BASE_URL=http://host.docker.internal:11434
